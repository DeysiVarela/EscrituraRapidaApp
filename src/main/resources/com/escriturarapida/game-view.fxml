<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.escriturarapida.controllers.GameController">
   <top>
      <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #2c3e50;">
         <children>
            <Label text="ESCRITURA RAPIDA" textFill="WHITE">
               <font>
                  <Font name="Arial Bold" size="28.0" />
               </font>
            </Label>
            <HBox alignment="CENTER" spacing="30.0">
               <children>
                  <Label fx:id="levelLabel" text="Nivel: 1" textFill="WHITE">
                     <font>
                        <Font name="Arial" size="16.0" />
                     </font>
                  </Label>
                  <Label fx:id="scoreLabel" text="Puntuacion: 0" textFill="WHITE">
                     <font>
                        <Font name="Arial" size="16.0" />
                     </font>
                  </Label>
                  <Label fx:id="timeLabel" text="Tiempo: 20" textFill="WHITE">
                     <font>
                        <Font name="Arial Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </top>
   <center>
      <VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #ecf0f1;">
         <children>
            <Label fx:id="wordLabel" text="palabra" textFill="#2c3e50">
               <font>
                  <Font name="Arial Bold" size="32.0" />
               </font>
            </Label>
            <TextField fx:id="inputField" promptText="Escribe la palabra aqui..." style="-fx-font-size: 18px;">
               <font>
                  <Font name="Arial" size="18.0" />
               </font>
            </TextField>
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="submitButton" mnemonicParsing="false" onAction="#handleSubmit" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 16px;" text="Enviar">
                     <font>
                        <Font name="Arial Bold" size="16.0" />
                     </font>
                  </Button>
                  <Button fx:id="restartButton" mnemonicParsing="false" onAction="#handleRestart" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 16px;" text="Reiniciar">
                     <font>
                        <Font name="Arial Bold" size="16.0" />
                     </font>
                  </Button>
                  <Button fx:id="letterModeButton" mnemonicParsing="false" onAction="#handleLetterMode" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 16px;" text="Modo Letras">
                     <font>
                        <Font name="Arial Bold" size="16.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            <Label fx:id="messageLabel" text="" textFill="#e74c3c">
               <font>
                  <Font name="Arial Bold" size="16.0" />
               </font>
            </Label>
            <Label fx:id="enteredLettersLabel" text="" textFill="#8e44ad">
               <font>
                  <Font name="Arial Bold" size="18.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
