<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>
<VBox spacing="10.0" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.example.typingspeed.ResultsController" stylesheets="@styles.css">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>
    <Label text="Game history" styleClass="title"/>
    <ListView fx:id="resultsList" prefHeight="240.0" prefWidth="420.0"/>
    <Button text="Close" onAction="#onCloseClicked" styleClass="btnPrimary"/>
</VBox>
