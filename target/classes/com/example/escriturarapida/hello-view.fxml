<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<VBox alignment="CENTER" spacing="12.0" xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.example.escriturarapida.HelloController"
    stylesheets="@styles.css" styleClass="root">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0" HBox.hgrow="ALWAYS">
        <Label fx:id="titleLabel" text="Escritura Rápida" styleClass="title"/>
        <HBox alignment="CENTER_RIGHT" spacing="12.0" HBox.hgrow="ALWAYS" styleClass="infoBox">
            <Label text="Tiempo:" />
            <Label fx:id="timeLabel" text="60" styleClass="timeValue" />
            <Label text="seg" />
            <Label text="Puntaje:" />
            <Label fx:id="scoreLabel" text="0" styleClass="scoreValue" />
        </HBox>
    </HBox>

    <Label fx:id="wordLabel" text="Presiona Start" styleClass="wordCard"/>

    <HBox spacing="8.0" alignment="CENTER">
        <TextField fx:id="inputField" promptText="Escribe la palabra" HBox.hgrow="ALWAYS"/>
        <Button text="Submit" onAction="#onSubmitClicked" styleClass="btnPrimary"/>
    </HBox>

    <HBox spacing="10.0" alignment="CENTER">
        <Button text="Start" onAction="#onStartClicked" styleClass="btnAccent"/>
        <Button text="Reiniciar" onAction="#onStartClicked" styleClass="btnSecondary"/>
        <Button text="Historial" onAction="#onShowHistoryClicked" styleClass="btnSecondary" accessibleText="Mostrar historial de partidas"/>
    </HBox>

    <Label fx:id="statusLabel" text="" styleClass="status"/>

</VBox>
