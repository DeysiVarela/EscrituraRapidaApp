<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<VBox alignment="CENTER" spacing="12.0" xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.example.typingspeed.HelloController"
    stylesheets="@styles.css" styleClass="root">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- Centered title -->
    <Label fx:id="titleLabel" text="Typing Speed" styleClass="title" />

    <!-- Prominent remaining time below the title -->
    <Label fx:id="timeLabel" text="60s" styleClass="timer" />

    <!-- Score display (controller expects fx:id=scoreLabel) -->
    <Label fx:id="scoreLabel" text="Score: 0" styleClass="scoreValue" />

    <Label fx:id="wordLabel" text="Press Start" styleClass="wordCard"/>

    <HBox spacing="8.0" alignment="CENTER">
        <TextField fx:id="inputField" promptText="Type the word" HBox.hgrow="ALWAYS"/>
        <Button text="✅ Submit" onAction="#onSubmitClicked" styleClass="btnPrimary"/>
    </HBox>

    <HBox spacing="10.0" alignment="CENTER">
        <Button text="⏱ Start" onAction="#onStartClicked" styleClass="btnAccent"/>
        <Button text="🔄 Restart" onAction="#onStartClicked" styleClass="btnSecondary"/>
        <Button text="📜 History" onAction="#onShowHistoryClicked" styleClass="btnSecondary" accessibleText="Show game history"/>
    </HBox>

    <Label fx:id="statusLabel" text="" styleClass="status"/>

</VBox>
